<controls:ESSpawningWindow
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client._ES.Spawning.Ui"
    xmlns:customControls="clr-namespace:Content.Client.Administration.UI.CustomControls"
    Title="{Loc 'es-spawn-menu-title'}"
    MinSize="950 530">
    <VFillStack Margin="10">
        <HScroll MinHeight="30" ReserveScrollbarSpace="True">
            <BoxContainer Name="StationCheckboxContainer" Orientation="Horizontal" SeparationOverride="20"/>
        </HScroll>
        <HFillStack HorizontalExpand="True">
            <VFillStack>
                <FillScroll HScrollEnabled="False">
                    <HFillStack HorizontalAlignment="Stretch" VerticalAlignment="Center" HorizontalExpand="True">
                        <VFillStack Name="JobContainer" Margin="5" SeparationOverride="10"/>
                        <Spacer HSpace="10"/>
                        <VFillStack Name="JobContainer2" Margin="5" SeparationOverride="10"/>
                    </HFillStack>
                </FillScroll>
            </VFillStack>
            <customControls:VSeparator Margin="10 0 10 30"/>
            <VStack>
                <controls:ESJobDisplay Name="JobDisplay" VerticalAlignment="Center" HorizontalAlignment="Center" VerticalExpand="True" SetWidth="200" Margin="10"/>
            </VStack>
        </HFillStack>
    </VFillStack>
</controls:ESSpawningWindow>
