<controls:ESCryptoNukeConsoleWindow
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client._ES.Nuke.Ui"
    xmlns:ui="clr-namespace:Content.Client.Pinpointer.UI"
    xmlns:graphics="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
    Title="{Loc 'es-cryptonuke-ui-window-title'}"
    Resizable="False">
    <HStack Margin="15" HorizontalExpand="True">
        <FillPanel>
            <PanelContainer.PanelOverride>
                <graphics:StyleBoxFlat BackgroundColor="#000000"/>
            </PanelContainer.PanelOverride>
            <HStack>
                <ui:NavMapControl Name="NavMap" VerticalExpand="True" HorizontalExpand="True" HorizontalAlignment="Left"/>
                <VStack Margin="10" VerticalExpand="True" HorizontalAlignment="Left">
                    <RichTextLabel Name="CompromisedLabel"/>
                    <RichTextLabel Name="CodesLabel"/>
                    <Spacer VSpace="15"/>
                    <RichTextLabel Name="HeaderLabel" Text="{Loc 'es-cryptonuke-ui-label-disk-header'}"/>
                    <RichTextLabel Name="LocationsLabel"/>
                    <Spacer VSpace="15"/>
                    <RichTextLabel Name="FlavorLabel" Text="{Loc 'es-cryptonuke-ui-label-flavor'}"/>
                    <Control VerticalExpand="True"/>
                    <Button Visible="False" Name="HackButton" Text="{Loc 'es-cryptonuke-ui-button-hack'}" VerticalAlignment="Bottom" StyleClasses="negative"/>
                </VStack>
                <Spacer HorizontalExpand="True"/>
            </HStack>
        </FillPanel>
    </HStack>
</controls:ESCryptoNukeConsoleWindow>
