<controls:ESAnomalyConsoleWindow
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client._ES.Telesci.Ui"
    xmlns:graphics="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
    Title="{Loc 'es-anomaly-console-ui-title'}"
    MinSize="600 350">
    <HStack Margin="15 10 15 15">
        <VFillStack>
            <ItemList Name="AnomalyList" SelectMode="Single" VerticalExpand="True"  HorizontalExpand="True"/>
        </VFillStack>
        <LowDivider Margin="10 0"/>
        <VFillStack SizeFlagsStretchRatio="2">
            <FillPanel>
                <PanelContainer.PanelOverride>
                    <graphics:StyleBoxFlat BackgroundColor="#000000" />
                </PanelContainer.PanelOverride>
                <VStack Margin="5">
                    <RichTextLabel Name="NameLabel" Text="{Loc 'es-anomaly-console-signal-none'}"/>
                    <Spacer VSpace="10"/>
                    <RichTextLabel Name="SequenceLabel"/>
                </VStack>
            </FillPanel>
        </VFillStack>
    </HStack>
</controls:ESAnomalyConsoleWindow>
