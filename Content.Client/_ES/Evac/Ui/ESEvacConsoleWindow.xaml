<controls:ESEvacConsoleWindow
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client._ES.Evac.Ui"
    MinSize="400 300"
    SetSize="480 330"
    Title="{Loc 'es-evac-computer-ui-title'}">
    <VScroll HorizontalExpand="True">
        <VStack Margin="10">
            <Panel VerticalAlignment="Top" StyleClasses="PanelBackgroundBaseDark">
                <HStack Margin="10">
                    <VStack Name="StationStatusNameContainer" VerticalExpand="True" SeparationOverride="5"/>
                    <Spacer HorizontalExpand="True"/>
                    <VStack Name="StationStatusStateContainer" VerticalExpand="True" SeparationOverride="5"/>
                </HStack>
            </Panel>
            <RichTextLabel Name="VoteStatusLabel" Margin="10 5" HorizontalAlignment="Left" StyleClasses="LabelSubText"/>
            <Spacer VSpace="10" VerticalExpand="True"/>
            <VStack Orientation="Vertical" VerticalAlignment="Bottom">
                <RichTextLabel Name="InfoLabel" HorizontalAlignment="Center" VerticalAlignment="Bottom" ReservesSpace="True"/>
                <Panel StyleClasses="PanelBackgroundBaseDark" SetSize="300 120" HorizontalAlignment="Center" VerticalExpand="True" Margin="0 5">
                    <HStack HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Name="ToggleButton" Text='{Loc "es-evac-computer-ui-button-enable-signal"}' MinSize="250 60"/>
                    </HStack>
                </Panel>
            </VStack>
        </VStack>
    </VScroll>
</controls:ESEvacConsoleWindow>
