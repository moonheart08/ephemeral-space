<controls:ESVotingWindow
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client._ES.Voting.Ui"
    Title="{Loc 'es-voter-ui-title'}"
    MinSize="580 400">
    <VScroll HorizontalExpand="True" Margin="10">
        <PanelContainer StyleClasses="PanelDark">
            <VFillStack Name="VotesContainer" VerticalExpand="True" Margin="10" SeparationOverride="5"/>
        </PanelContainer>
    </VScroll>
</controls:ESVotingWindow>
