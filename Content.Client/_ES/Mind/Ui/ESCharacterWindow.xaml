<controls:ESCharacterWindow
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client._ES.Mind.Ui"
    Title="{Loc 'es-character-info-title'}"
    MinSize="725 425"
    SetWidth="725"
    SetHeight="575">
    <HStack Margin="10 5 10 10">
        <VStack SetWidth="270">
            <VStack VerticalExpand="True" VerticalAlignment="Bottom" SizeFlagsStretchRatio="3">
                <TextureButton Name="MaskHelpButton" StyleClasses="windowHelpButton" VerticalAlignment="Center" HorizontalAlignment="Right" Disabled="True" Visible="False" />
                <VStack HorizontalAlignment="Center">
                    <RichTextLabel Name="MaskLabel" Margin="20 0" HorizontalAlignment="Center"/>
                    <LowDivider/>
                    <RichTextLabel Name="TroupeLabel" HorizontalAlignment="Center"/>
                </VStack>
                <SpriteView Name="SelfView" OverrideDirection="South" Scale="4 4" HorizontalAlignment="Center" Margin="5 5 5 15"/>
                <RichTextLabel Name="NameLabel" HorizontalAlignment="Center" Margin="10 0"/>
                <HStack HorizontalAlignment="Center">
                    <TextureRect Name="JobIconTexture" TextureScale="2 2" VerticalAlignment="Center"/>
                    <Spacer HSpace="5"/>
                    <RichTextLabel Name="JobLabel" VerticalAlignment="Center"/>
                </HStack>
            </VStack>
            <VStack HorizontalAlignment="Center" VerticalAlignment="Center" VerticalExpand="True" SizeFlagsStretchRatio="2">
                <RichTextLabel Name="CharacterInfoLabel" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                <Spacer VSpace="10"/>
                <RichTextLabel Name="PromptLabel" HorizontalAlignment="Center" Margin="10 0"/>
                <Spacer VSpace="10"/>
                <RichTextLabel Name="LikesLabel" HorizontalAlignment="Center"/>
                <RichTextLabel Name="DislikesLabel" HorizontalAlignment="Center"/>
            </VStack>
        </VStack>
        <LowDivider Margin="10 0"/>
        <VFillStack>
            <HStack>
                <RichTextLabel Name="InfoBlurbText" HorizontalExpand="False"/>
            </HStack>
            <RichTextLabel Name="ObjectiveHeaderLabel" Text="{Loc 'es-character-window-objective-title'}" Margin="0 0 0 5"/>
            <FillPanel StyleClasses="PanelDark">
                <VScroll HorizontalExpand="True" VerticalExpand="True">
                    <GridContainer Name="ObjectivesContainer" Columns="1" RectClipContent="True" Margin="10 10"/>
                </VScroll>
            </FillPanel>
        </VFillStack>
    </HStack>
</controls:ESCharacterWindow>
